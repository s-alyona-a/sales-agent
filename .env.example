# ─── GigaChat (необязательно — без него работает прямой сбор) ───
GIGACHAT_API_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_CORP
# GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1  # для корпоративного доступа
GIGACHAT_MODEL=GigaChat-2-Pro
GIGACHAT_TEMPERATURE=0.1
GIGACHAT_MAX_TOKENS=4096

# ─── OpenSearch — подключение к ИФТ стенду (из-под впн ИФТ) ───────────────────
OPENSEARCH_HOST=10.10.22.6
OPENSEARCH_PORT=9200
OPENSEARCH_USER=langflow_l
OPENSEARCH_PASSWORD=
OPENSEARCH_USE_SSL=false
OPENSEARCH_VERIFY_CERTS=false

# ─── CRM — моковые данные из JSON-файла ────────────────────────
CRM_TYPE=mock

# ─── Web Search ─────────────────────────────────────────────────
# DDGS_PROXY="" не надо заполнять
WEB_READ_TIMEOUT=30
MAX_PAGES_TO_READ=5

# ─── Порт API сервера ──────────────────────────────────────────
SALES_AGENT_PORT=8900